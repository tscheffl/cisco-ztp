hostname {{ hostname }}
!
interface GigabitEthernet 0/0/0
 description Management Interface
 ip address {{ mgmt_ip }} 255.255.255.0
 no ip dhcp client client-id
 no shutdown
!
username admin privilege 15 secret Cisco123
!
line vty 0 4
 login local
 transport input ssh
!
license smart transport off
!
end
